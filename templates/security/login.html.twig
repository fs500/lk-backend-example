{% extends 'login.html.twig' %}
{% block title %}Авторизация{% endblock %}

{% block body_header %}Авторизация{% endblock %}

{% block body %}
<form method="post">
    {% if error %}
        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    {% if app.user %}
        <div class="mb-3">
            Вы авторизованы как {{ app.user.username }}, <a href="{{ path('logout') }}">выход</a>
        </div>
    {% endif %}
    <div class="form-group field-text">
        <label for="username" class="sr-only form-control-label required">Имя пользователя</label>
        <div class="form-widget form-widget-with-icon">
            <i class="fa fa-fw fa-user"></i>
            <input type="text" value="{{ last_username }}" name="username" id="username" class="form-control" required autofocus placeholder="Имя пользователя">
        </div>
    </div>
    <div class="form-group field-text">
        <label for="password" class="sr-only form-control-label required">Пароль</label>
        <div class="form-widget form-widget-with-icon">
            <i class="fa fa-fw fa-lock"></i>
            <input type="password" name="password" id="password" class="form-control" required placeholder="Пароль">
        </div>
    </div>

    <input type="hidden" name="_csrf_token"
           value="{{ csrf_token('authenticate') }}"
    >

    {#
        Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
        See https://symfony.com/doc/current/security/remember_me.html

        <div class="checkbox mb-3">
            <label>
                <input type="checkbox" name="_remember_me"> Remember me
            </label>
        </div>
    #}
    <div class="form-group field-button">
        <button type="submit" class="btn btn-primary btn-lg btn-block">Авторизация</button>
    </div>
</form>
{% endblock %}
