{# @var eye_admin \Eyetronic\EyeAdminBundle\Context\AdminContext #}
{# @var documents App\Entity\Document[] #}
{% extends '@EyeAdmin/dashboard-base.html.twig' %}

{% block title %}Документы{% endblock %}

{% block content_header_title %}Документы{% endblock %}

{% block page_actions %}<a class="action-new btn btn-primary btn-sm" href="{{ path('admin_document_new') }}">Добавить</a>{% endblock %}

{% block body %}
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Название</th>
                <th>Дата</th>
                <th>Файл</th>
                <th class="list-options"></th>
            </tr>
        </thead>
        <tbody>
        {% for document in documents %}
            <tr>
                <td>{{ document.header }}</td>
                <td>{{ document.date ? document.date|date('d.m.Y') : '' }}</td>
                <td>
                    {% if document.file %}
                        <a href="{{ vich_uploader_asset(document, 'uploadedFile') }}" target="_blank">скачать</a>
                    {% endif %}
                </td>
                <td class="list-actions">
                    <a class="fa fa-icons fa-pencil-square-o list-edit-button" href="{{ path('admin_document_edit', {'id': document.id}) }}"></a>
                    <a class="fas fa-eye list-detail-button" href="{{ path('admin_document_show', {'id': document.id}) }}"></a>
                    <a class="fas fa-trash-alt list-remove-button" data-id="{{ document.id }}" href="{{ path('admin_document_delete', {'id': document.id}) }}"></a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Нет записей</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <form class="delete-form" method="post" data-action="{{ path('admin_document_delete', {'id': '__id__'}) }}">
        <input type="hidden" name="_method" value="DELETE">
    </form>
{% endblock %}
