{# @var eye_admin \Eyetronic\EyeAdminBundle\Context\AdminContext #}
{# @var offers App\Entity\Offer[] #}
{% extends '@EyeAdmin/dashboard-base.html.twig' %}

{% block title %}Акции{% endblock %}

{% block content_header_title %}Акции{% endblock %}

{% block page_actions %}<a class="action-new btn btn-primary btn-sm" href="{{ path('admin_offer_new') }}">Добавить</a>{% endblock %}

{% block body %}
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Название</th>
                <th>Дата окончания</th>
                <th>Иконка</th>
                <th class="list-options"></th>
            </tr>
        </thead>
        <tbody>
        {% for offer in offers %}
            <tr>
                <td>{{ offer.header }}</td>
                <td>{{ offer.deadline ? offer.deadline|date('d.m.Y') : '' }}</td>
                <td>
                {% if offer.icon %}
                    <img src="{{ vich_uploader_asset(offer, 'iconFile') }}" alt="">
                {% endif %}
                </td>
                <td class="list-actions">
                    <a class="fa fa-icons fa-pencil-square-o list-edit-button" href="{{ path('admin_offer_edit', {'id': offer.id}) }}"></a>
                    <a class="fas fa-eye list-detail-button" href="{{ path('admin_offer_show', {'id': offer.id}) }}"></a>
                    <a class="fas fa-trash-alt list-remove-button" data-id="{{ offer.id }}" href="{{ path('admin_offer_delete', {'id': offer.id}) }}"></a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Нет записей</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <form class="delete-form" method="post" data-action="{{ path('admin_offer_delete', {'id': '__id__'}) }}">
        <input type="hidden" name="_method" value="DELETE">
    </form>
{% endblock %}
