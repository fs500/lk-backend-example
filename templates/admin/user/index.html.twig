{# @var eye_admin \Eyetronic\EyeAdminBundle\Context\AdminContext #}
{% extends '@EyeAdmin/dashboard-base.html.twig' %}

{% block title %}Пользователи{% endblock %}

{% block page_actions %}<a class="action-new btn btn-primary btn-sm" href="{{ path('admin_user_new') }}">Добавить</a>{% endblock %}

{% block content_header_title %}Пользователи{% endblock %}

{% block body %}
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Id</th>
                <th>Имя пользователя</th>
                <th>Роли</th>
                <th>Email</th>
                <th>Создан</th>
                <th class="list-options"></th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.username }}</td>
                <td>{{ user.roles ? user.rolesDescription }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.created ? user.created|date('Y-m-d H:i:s') : '' }}</td>
                <td class="list-actions">
                    <a class="fa fa-icons fa-pencil-square-o list-edit-button" href="{{ path('admin_user_edit', {'id': user.id}) }}" title="редактировать"></a>
                    <a class="fas fa-eye list-detail-button" href="{{ path('admin_user_show', {'id': user.id}) }}" title="просмотр"></a>
                    {% if app.user.id != user.id %}
                    <a class="fas fa-trash-alt list-remove-button" data-id="{{ user.id }}" href="{{ path('admin_user_delete', {'id': user.id}) }}" title="удалить"></a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">записей не найдено</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <form class="delete-form" method="post" data-action="{{ path('admin_user_delete', {'id': '__id__'}) }}">
        <input type="hidden" name="_method" value="DELETE">
    </form>
{% endblock %}
