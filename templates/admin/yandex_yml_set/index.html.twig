{# @var eye_admin \Eyetronic\EyeAdminBundle\Context\AdminContext #}
{# @var yandex_yml_sets App\Entity\YandexYmlSet[] #}
{% extends '@EyeAdmin/dashboard-base.html.twig' %}

{% block title %}Сеты{% endblock %}

{% block content_header_title %}Сеты{% endblock %}

{% block page_actions %}<a class="action-new btn btn-primary btn-sm" href="{{ path('admin_yandex_yml_set_new') }}">Добавить</a>{% endblock %}

{% block body %}
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>#</th>
                <th>Название</th>
                <th>Url</th>
                <th class="list-options"></th>
            </tr>
        </thead>
        <tbody>
        {% for yandex_yml_set in yandex_yml_sets %}
            <tr>
                <td>{{ yandex_yml_set.id }}</td>
                <td>{{ yandex_yml_set.name }}</td>
                <td>{{ yandex_yml_set.url }}</td>
                <td class="list-actions">
                    <a class="fa fa-icons fa-pencil-square-o list-edit-button" href="{{ path('admin_yandex_yml_set_edit', {'id': yandex_yml_set.id}) }}"></a>
                    <a class="fas fa-eye list-detail-button" href="{{ path('admin_yandex_yml_set_show', {'id': yandex_yml_set.id}) }}"></a>
                    <a class="fas fa-trash-alt list-remove-button" data-id="{{ yandex_yml_set.id }}" href="{{ path('admin_yandex_yml_set_delete', {'id': yandex_yml_set.id}) }}"></a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Нет записей</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <form class="delete-form" method="post" data-action="{{ path('admin_yandex_yml_set_delete', {'id': '__id__'}) }}">
        <input type="hidden" name="_method" value="DELETE">
    </form>
{% endblock %}
