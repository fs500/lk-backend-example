{# @var eye_admin \Eyetronic\EyeAdminBundle\Context\AdminContext #}
{# @var notifications App\Entity\Notification[] #}
{% extends '@EyeAdmin/dashboard-base.html.twig' %}

{% block title %}Уведомления{% endblock %}

{% block content_header_title %}Уведомления{% endblock %}

{% block page_actions %}<a class="action-new btn btn-primary btn-sm" href="{{ path('admin_notification_new') }}">Добавить</a>{% endblock %}

{% block body %}
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Заголовок</th>
                <th>Дата начала показа</th>
                <th>Дата окончания показа</th>
                <th class="list-options"></th>
            </tr>
        </thead>
        <tbody>
        {% for notification in notifications %}
            <tr>
                <td>{{ notification.header }}</td>
                <td>{{ notification.dateStart ? notification.dateStart|date('d.m.Y') : '' }}</td>
                <td>{{ notification.dateFinish ? notification.dateFinish|date('d.m.Y') : '' }}</td>
                <td class="list-actions">
                    <a class="fa fa-icons fa-pencil-square-o list-edit-button" href="{{ path('admin_notification_edit', {'id': notification.id}) }}"></a>
                    <a class="fas fa-eye list-detail-button" href="{{ path('admin_notification_show', {'id': notification.id}) }}"></a>
                    <a class="fas fa-trash-alt list-remove-button" data-id="{{ notification.id }}" href="{{ path('admin_notification_delete', {'id': notification.id}) }}"></a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">Нет записей</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <form class="delete-form" method="post" data-action="{{ path('admin_notification_delete', {'id': '__id__'}) }}">
        <input type="hidden" name="_method" value="DELETE">
    </form>
{% endblock %}
