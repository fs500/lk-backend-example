{# @var eye_admin \Eyetronic\EyeAdminBundle\Context\AdminContext #}
{# @var infrastructures App\Entity\Infrastructure #}
{% extends '@EyeAdmin/dashboard-base.html.twig' %}

{% block title %}Группа инфраструктуры{% endblock %}

{% block content_header_title %}Группа инфраструктуры{% endblock %}

{% block page_actions %}
<a class="action-list btn btn-primary btn-sm" href="{{ path('admin_infrastructure_index') }}">Список</a>
<a class="action-edit btn btn-success btn-sm" href="{{ path('admin_infrastructure_edit', {'id': infrastructure.id}) }}">Редактировать</a>
{% endblock %}

{% block body %}
    <table class="table">
        <tbody>
            <tr>
                <th>#</th>
                <td>{{ infrastructure.id }}</td>
            </tr>
            <tr>
                <th>Название</th>
                <td>{{ infrastructure.header }}</td>
            </tr>
            <tr>
                <th>Количество объектов</th>
                <td>
                    <span class="badge badge-light">{{ infrastructure.items | length }}</span>
                </td>
            </tr>
            <tr>
                <th>Значок</th>
                <td>
                    {% if infrastructure.icon %}
                        <img src="{{ vich_uploader_asset(infrastructure, 'iconFile') }}" alt="">
                    {% endif %}
                </td>
            </tr>
        </tbody>
    </table>
{% endblock %}
