{# @var eye_admin \Eyetronic\EyeAdminBundle\Context\AdminContext #}
{# @var menus App\Entity\Menu[] #}
{% extends '@EyeAdmin/dashboard-base.html.twig' %}

{% block title %}Меню{% endblock %}

{% block content_header_title %}Меню{% endblock %}

{% block page_actions %}<a class="action-new btn btn-primary btn-sm" href="{{ path('admin_menu_new') }}">Добавить</a>{% endblock %}

{% block body %}
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Название</th>
                <th class="list-options"></th>
            </tr>
        </thead>
        <tbody>
        {% for menu in menus %}
            <tr>
                <td>{{ menu.header }}</td>
                <td class="list-actions">
                    <a class="fa fa-icons fa-pencil-square-o list-edit-button" href="{{ path('admin_menu_edit', {'id': menu.id}) }}"></a>
                    <a class="fas fa-eye list-detail-button" href="{{ path('admin_menu_show', {'id': menu.id}) }}"></a>
                    <a class="fas fa-trash-alt list-remove-button" data-id="{{ menu.id }}" href="{{ path('admin_menu_delete', {'id': menu.id}) }}"></a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Нет записей</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <form class="delete-form" method="post" data-action="{{ path('admin_menu_delete', {'id': '__id__'}) }}">
        <input type="hidden" name="_method" value="DELETE">
    </form>
{% endblock %}
