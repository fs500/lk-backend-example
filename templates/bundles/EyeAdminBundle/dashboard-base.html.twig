{# @var eye_admin \Eyetronic\EyeAdminBundle\Context\AdminContext #}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Панель администратора{% endblock %}</title>
    {{ encore_entry_link_tags('dashboard') }}
    {{ encore_entry_link_tags('adminCss') }}
    {% block stylesheets %}{% endblock %}

    {{ encore_entry_script_tags('dashboard') }}
    {% block javascripts %}{% endblock %}
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon/16x16.png?v=1">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon/32x32.png?v=1">
</head>
<body class="dashboard image-theme theme-italy">
<nav class="navbar navbar-dark bg-dark flex-md-nowrap p-0 topbar">
    <a class="navbar-brand col-sm-3 col-md-2 mr-0" href="{{ path('admin') }}">{{ site_name }}</a>
    <ul class="navbar-nav px-3">
        <li class="nav-item text-nowrap">
            <a class="nav-link" href="{{ path('logout') }}">Выход</a>
        </li>
    </ul>
</nav>
<div class="container-fluid">
    <div class="row">
        {% block sidebar %}
            {{ include('@EyeAdmin/menu.html.twig') }}
        {% endblock %}
        <main role="main" class="col-md-9 ml-sm-auto col-lg-10 pt-3 px-4">
            <div class="content-header">
                <div class="d-flex flex-row justify-content-between align-content-center w-100">
                    {% block content_header %}
                        <div class="content-header-title"><h1 class="title">{% block content_header_title %}{% endblock %}</h1></div>
                        <div class="page-actions">{% block page_actions %}{% endblock %}</div>
                    {% endblock %}
                </div>
            </div>
            {% block body %}{% endblock %}
        </main>
    </div>
</div>
</body>
</html>
